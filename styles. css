body {
    margin: 0;
    font-family: Arial, sans-serif;
    background-color: #f8f5f2;
}

.header {
    background-color: #4b2e2e;
    color: white;
    text-align: center;
    padding: 20px;
}

.header h1 {
    margin: 0;
    font-size: 32px;
}

section {
    padding: 20px;
}

.overview {
    background-color: #fff;
}

.gallery img {
    width: 100%;
    max-width: 300px;
    margin: 10px;
    border-radius: 10px;
}

.menu {
    background-color: #f1e3d3;
}

.menu h2 {
    text-align: center;
}

.menu-category {
    margin-bottom: 20px;
}

.menu-category h3 {
    color: #4b2e2e;
}

ul {
    list-style: none;
    padding: 0;
}

li {
    padding: 5px 0;
    border-bottom: 1px solid #ccc;
}
